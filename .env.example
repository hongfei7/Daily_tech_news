# GitHub Personal Access Token (optional, increases rate limits)
GITHUB_TOKEN=your_github_token_here

# HuggingFace API (optional)
HF_TOKEN=your_hf_token_here

# Database path (default: data/tech_trends.db)
DB_PATH=data/tech_trends.db

# Log level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Number of days to look back when fetching data
FETCH_DAYS_BACK=1

# Max items per source per run
MAX_ITEMS_PER_SOURCE=50
